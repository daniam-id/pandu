{
  "name": "pandu-backend",
  "version": "1.0.0",
  "description": "Pandu.ai - Agentic Routing Engine Backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "deploy:rules": "echo '=== Deploy Firestore Rules ===' && firebase deploy --only firestore:rules --project ${FIREBASE_PROJECT_ID} && echo '=== Deploy Storage Rules ===' && firebase deploy --only storage --project ${FIREBASE_PROJECT_ID}",
    "deploy:preview": "gcloud builds submit --config=cloudbuild.yaml --no-source --dry-run",
    "deploy:prod": "gcloud builds submit --config=cloudbuild.yaml ."
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "firebase-admin": "^12.6.0",
    "helmet": "^8.1.0",
    "multer": "^1.4.5-lts.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
