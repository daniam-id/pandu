# ================================================================
# Pandu.ai Backend — Environment Variables
# ================================================================
# ⚠️  JANGAN commit .env ke Git.
# Gunakan file ini sebagai template. Copy ke .env untuk development.
#
# Environment:
#   Development  → .env (lokal, git-ignored)
#   Production   → Secret Manager + Cloud Run env injection
#   CI/CD        → Cloud Build substitutions + Secret Manager
# ================================================================

# ── Firebase ───────────────────────────────────────────────────
# PRODUCTION: Gunakan Secret Manager (FIREBASE_PRIVATE_KEY)
# DEVELOPMENT: Gunakan FIREBASE_PRIVATE_KEY_PATH + file JSON lokal
#
# Option A: Base64 service account (Cloud Run / CI)
FIREBASE_SERVICE_ACCOUNT_BASE64=base64_encoded_service_account_json
# Option B: Individual fields (Cloud Run direct injection)
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY=your_private_key_with_newlines_as_\n
FIREBASE_CLIENT_EMAIL=your_firebase_client_email@your_project.iam.gserviceaccount.com
# Option C: Local file path (development only)
FIREBASE_PRIVATE_KEY_PATH=/path/to/your/firebase-private-key.json

FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com

# ── Google AI Studio (Gemini) ──────────────────────────────────
# PRODUCTION: Secret Manager (jangan hardcode)
# DEVELOPMENT: .env untuk testing lokal
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL_VERSION=gemini-3.1-flash-lite-preview

# ── Google Maps ────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# ── Application ────────────────────────────────────────────────
PORT=8080

# API Key untuk REST endpoints (x-api-key header)
# PRODUCTION: Minimal 32 karakter, random hex
# Contoh generate: openssl rand -hex 32
API_SECRET_KEY=your_api_key_for_demo
API_KEY=your_api_key_for_demo

# CORS — PRODUCTION: set ke domain spesifik (contoh: https://dispatcher.yourdomain.com,https://driver.yourdomain.com)
CORS_ORIGIN=*

# Real-time tuning
LOCATION_BROADCAST_INTERVAL_MS=15000
ROUTE_CACHE_TTL_MS=60000

# Logging — PRODUCTION: info, DEVELOPMENT: debug
LOG_LEVEL=info
