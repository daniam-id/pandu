# Pandu.ai Backend Environment Variables
# Copy this file to .env and fill in the values with your own secrets

# Firebase Configuration
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_PRIVATE_KEY_PATH=/path/to/your/firebase-private-key.json
FIREBASE_CLIENT_EMAIL=your_firebase_client_email@your_project.iam.gserviceaccount.com

# Google AI Studio (Gemini)
GEMINI_API_KEY=your_gemini_api_key

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Application
PORT=8080
API_KEY=your_api_key_for_demo