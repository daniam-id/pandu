# Firebase Client SDK config (for Firestore onSnapshot listeners)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Backend REST API base URL (includes /api/v1 prefix)
REACT_APP_API_BASE_URL=https://pandu-backend-879040945141.asia-southeast2.run.app/api/v1

# Backend API Key. Required for all /api/v1/* requests via x-api-key header.
# See INTEGRATION_STATUS.md for the active hackathon key.
REACT_APP_API_KEY=

# Google Maps JavaScript API key
REACT_APP_GOOGLE_MAPS_API_KEY=

# Hardcoded courier identifier this device represents (one courier per device)
REACT_APP_COURIER_ID=courier_device_001
